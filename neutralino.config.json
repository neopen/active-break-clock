{
  "appname": "HealthClock",
  "version": "0.5.3",
  "description": "一款强制锁屏的健康提醒应用，帮你打破久坐循环，养成定时活动的好习惯。",
  "main": "src/main/index.js",
  "url": "/",
  "port": 0,
  "enableHTTPS": false,
  "globalVariables": {
    "NL_VERSION": "${NL_VERSION}",
    "NL_PORT": "${NL_PORT}"
  },
  "window": {
    "main": {
      "title": "起来走走 - 拒绝久坐",
      "width": 500, 
      "height": 750, 
      "minWidth": 400,
      "minHeight": 600,
      "resizable": true,
      "fullscreen": false,
      "alwaysOnTop": false,
      "center": true,
      "icon": "src/renderer/icons/icon-256.png",
      "label": "main",
      "transparent": false,
      "shadow": true,
      "defaultBackgroundOpacity": 1,
      "enableInspector": true,
      "windowControls": {
        "hide": false,
        "maximize": true,
        "minimize": true
      }
    },
    "lock": {
      "title": "起来走走 - 锁屏",
      "width": 1920,
      "height": 1080,
      "resizable": false,
      "fullscreen": true,
      "alwaysOnTop": true,
      "center": false,
      "icon": "src/renderer/icons/icon-256.png",
      "label": "lock",
      "transparent": false,
      "shadow": false,
      "defaultBackgroundOpacity": 1,
      "enableInspector": false,
      "windowControls": {
        "hide": true,
        "maximize": false,
        "minimize": false
      }
    }
  },
  "tray": {
    "enabled": true,
    "icon": "src/renderer/icons/icon-48.png",
    "menu": [
      {
        "label": "显示主窗口",
        "event": "showMainWindow"
      },
      {
        "label": "退出",
        "event": "exitApp"
      }
    ]
  },
  "security": {
    "permissions": [
      "app.*",
      "window.*",
      "filesystem.*",
      "os.*",
      "process.*",
      "debug.*",
      "storage.*",
      "events.*" 
    ]
  },
  "modes": {
    "window": {
      "args": [],
      "env": {}
    },
    "browser": {
      "args": [],
      "env": {}
    },
    "cloud": {
      "args": [],
      "env": {}
    }
  },
  "cli": {
    "mirrorUrl": "https://npmmirror.com/mirrors/neutralinojs/",
    "binaryName": "HealthClock",
    "resourcesPath": "src/renderer",
    "extensionsPath": "src/extensions",
    "libraryPath": "src/main",
    "binaryVersion": "6.7.0"
  }
}